{
  "StartClubCheckIn": {
    "timeout": 8000,
    "rate_limit": 250,
    "next": [
      "[JumpBack]NavLoading",
      "WaitSocialPageOpened",
      "[JumpBack]NavOpenCommunication"
    ],
    "on_error": [
      "ReturnClubToMain"
    ]
  },
  "WaitSocialPageOpened": {
    "recognition": "TemplateMatch",
    "template": "club/social_club_card.png",
    "roi": [
      150,
      280,
      350,
      220
    ],
    "threshold": 0.65,
    "timeout": 1500,
    "next": [
      "OpenClubFromSocial"
    ]
  },
  "OpenClubFromSocial": {
    "recognition": "TemplateMatch",
    "template": "club/social_club_card.png",
    "roi": [
      150,
      280,
      350,
      220
    ],
    "threshold": 0.65,
    "action": "Click",
    "post_wait_freezes": 500,
    "next": [
      "OpenClubLoading",
      "WaitClubPageOpened",
      "OpenClubFromSocial"
    ],
    "timeout": 1500
  },
  "OpenClubLoading": {
    "recognition": "TemplateMatch",
    "template": "nav/loading.png",
    "threshold": 0.7,
    "post_wait_freezes": 300,
    "next": [
      "OpenClubLoading",
      "WaitClubPageOpened"
    ],
    "timeout": 700,
    "rate_limit": 100
  },
  "WaitClubPageOpened": {
    "recognition": "TemplateMatch",
    "template": "club/club_page_title.png",
    "roi": [
      70,
      0,
      170,
      70
    ],
    "threshold": 0.7,
    "timeout": 2000,
    "next": [
      "HandleClubSignInReward"
    ],
    "on_error": [
      "RetryOpenClubFromSocialAfterCheck"
    ]
  },
  "RetryOpenClubFromSocialAfterCheck": {
    "next": [
      "OpenClubFromSocial"
    ]
  },
  "HandleClubSignInReward": {
    "next": [
      "ConfirmClubSignInReward",
      "ReturnClubToMain"
    ]
  },
  "ConfirmClubSignInReward": {
    "recognition": "TemplateMatch",
    "template": "club/signin_reward_confirm.png",
    "roi": [
      480,
      420,
      340,
      130
    ],
    "threshold": 0.75,
    "action": "Click",
    "pre_wait_freezes": 500,
    "post_wait_freezes": 800,
    "timeout": 1500,
    "next": [
      "WaitClubSignInRewardGone"
    ]
  },
  "WaitClubSignInRewardGone": {
    "recognition": "TemplateMatch",
    "template": "club/signin_reward_title.png",
    "roi": [
      500,
      120,
      320,
      100
    ],
    "threshold": 0.7,
    "inverse": true,
    "timeout": 2000,
    "next": [
      "ReturnClubToMain"
    ],
    "on_error": [
      "RetryConfirmClubSignInRewardAfterStillVisible"
    ]
  },
  "RetryConfirmClubSignInRewardAfterStillVisible": {
    "next": [
      "ConfirmClubSignInRewardSecond",
      "ReturnClubToMainFallbackAfterRewardRetry"
    ]
  },
  "ConfirmClubSignInRewardSecond": {
    "recognition": "TemplateMatch",
    "template": "club/signin_reward_confirm.png",
    "roi": [
      480,
      420,
      340,
      130
    ],
    "threshold": 0.75,
    "action": "Click",
    "pre_wait_freezes": 500,
    "post_wait_freezes": 800,
    "timeout": 1500,
    "next": [
      "WaitClubSignInRewardGoneAfterRetry"
    ],
    "on_error": [
      "ReturnClubToMainFallbackAfterRewardRetry"
    ]
  },
  "WaitClubSignInRewardGoneAfterRetry": {
    "recognition": "TemplateMatch",
    "template": "club/signin_reward_title.png",
    "roi": [
      500,
      120,
      320,
      100
    ],
    "threshold": 0.7,
    "inverse": true,
    "timeout": 2000,
    "next": [
      "ReturnClubToMain"
    ],
    "on_error": [
      "ReturnClubToMainFallbackAfterRewardRetry"
    ]
  },
  "ReturnClubToMainFallbackAfterRewardRetry": {
    "next": [
      "ReturnClubToMain"
    ]
  },
  "ReturnClubToMain": {
    "next": [
      "NavReturnToMain"
    ]
  }
}
