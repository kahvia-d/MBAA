{
  "StartMailboxClaim": {
    "timeout": 8000,
    "rate_limit": 250,
    "next": [
      "[JumpBack]NavOpenMailbox",
      "[JumpBack]NavLoading",
      "WaitMailboxClaimPageOpened"
    ],
    "on_error": [
      "ReturnMailboxClaimToMain"
    ]
  },
  "WaitMailboxClaimPageOpened": {
    "recognition": "TemplateMatch",
    "template": "mail/mail_title.png",
    "roi": [
      80,
      0,
      140,
      70
    ],
    "threshold": 0.7,
    "timeout": 1500,
    "next": [
      "ClickMailboxClaimAllButton",
      "ReturnMailboxClaimToMainNoClaim"
    ]
  },
  "ClickMailboxClaimAllButton": {
    "recognition": "TemplateMatch",
    "template": "mail/claim_all_button.png",
    "roi": [
      990,
      615,
      290,
      105
    ],
    "threshold": 0.75,
    "action": "Click",
    "post_wait_freezes": 500,
    "timeout": 1200,
    "next": [
      "WaitMailboxClaimRewardSuccess"
    ],
    "on_error": [
      "ReturnMailboxClaimToMainNoClaim"
    ]
  },
  "ReturnMailboxClaimToMainNoClaim": {
    "next": [
      "ReturnMailboxClaimToMain"
    ]
  },
  "WaitMailboxClaimRewardSuccess": {
    "recognition": "TemplateMatch",
    "template": "common/reward_success.png",
    "threshold": 0.8,
    "action": "Click",
    "target": [
      640,
      650
    ],
    "post_wait_freezes": 800,
    "timeout": 10000,
    "next": [
      "WaitMailboxClaimRewardSuccessClosed"
    ],
    "on_error": [
      "ContinueMailboxClaimAfterRewardTimeout"
    ],
    "roi": [
      350,
      60,
      580,
      220
    ]
  },
  "WaitMailboxClaimRewardSuccessClosed": {
    "recognition": "TemplateMatch",
    "template": "common/reward_success.png",
    "threshold": 0.8,
    "inverse": true,
    "timeout": 1000,
    "next": [
      "ReturnMailboxClaimToMainAfterReward"
    ],
    "on_error": [
      "RetryCloseMailboxClaimRewardSuccess"
    ],
    "roi": [
      350,
      60,
      580,
      220
    ]
  },
  "RetryCloseMailboxClaimRewardSuccess": {
    "action": "Click",
    "target": [
      640,
      650
    ],
    "post_wait_freezes": 800,
    "next": [
      "WaitMailboxClaimRewardSuccessClosed"
    ]
  },
  "ContinueMailboxClaimAfterRewardTimeout": {
    "action": "Click",
    "target": [
      640,
      650
    ],
    "post_wait_freezes": 800,
    "next": [
      "ReturnMailboxClaimToMainAfterReward"
    ]
  },
  "ReturnMailboxClaimToMainAfterReward": {
    "next": [
      "ReturnMailboxClaimToMain"
    ]
  },
  "ReturnMailboxClaimToMain": {
    "next": [
      "NavReturnToMain"
    ]
  }
}
