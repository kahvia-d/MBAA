{
  "StartMailboxClaim": {
    "timeout": 8000,
    "rate_limit": 250,
    "next": [
      "[JumpBack]NavOpenMailbox",
      "[JumpBack]NavLoading",
      "WaitMailboxClaimPageOpened"
    ],
    "on_error": [
      "ReturnMailboxClaimToMain"
    ]
  },
  "WaitMailboxClaimPageOpened": {
    "recognition": "TemplateMatch",
    "template": "mail/mail_title.png",
    "roi": [
      80,
      0,
      140,
      70
    ],
    "threshold": 0.7,
    "timeout": 1500,
    "next": [
      "ClickMailboxClaimAllButton",
      "ReturnMailboxClaimToMainNoClaim"
    ]
  },
  "ClickMailboxClaimAllButton": {
    "recognition": "TemplateMatch",
    "template": "mail/claim_all_button.png",
    "roi": [
      990,
      615,
      290,
      105
    ],
    "threshold": 0.75,
    "action": "Click",
    "post_wait_freezes": 500,
    "timeout": 5000,
    "next": [
      "WaitMailboxClaimRewardSuccess"
    ],
    "on_error": [
      "ReturnMailboxClaimToMainNoClaim"
    ]
  },
  "ReturnMailboxClaimToMainNoClaim": {
    "next": [
      "ReturnMailboxClaimToMain"
    ]
  },
  "WaitMailboxClaimRewardSuccess": {
    "recognition": "TemplateMatch",
    "template": "common/reward_success.png",
    "roi": [
      430,
      95,
      450,
      170
    ],
    "threshold": 0.7,
    "timeout": 30000,
    "rate_limit": 250,
    "next": [
      "CloseMailboxClaimRewardSuccess"
    ],
    "on_error": [
      "RetryCloseMailboxClaimRewardSuccess"
    ]
  },
  "CloseMailboxClaimRewardSuccess": {
    "recognition": "TemplateMatch",
    "template": "common/reward_continue.png",
    "roi": [
      480,
      590,
      330,
      80
    ],
    "threshold": 0.75,
    "action": "Click",
    "target": [
      640,
      632
    ],
    "post_wait_freezes": 800,
    "timeout": 3000,
    "next": [
      "WaitMailboxClaimRewardSuccessClosed"
    ],
    "on_error": [
      "RetryCloseMailboxClaimRewardSuccess"
    ]
  },
  "WaitMailboxClaimRewardSuccessClosed": {
    "recognition": "TemplateMatch",
    "template": "common/reward_success.png",
    "threshold": 0.7,
    "inverse": true,
    "next": [
      "ReturnMailboxClaimToMainAfterReward"
    ],
    "roi": [
      430,
      95,
      450,
      170
    ]
  },
  "RetryCloseMailboxClaimRewardSuccess": {
    "max_hit": 5,
    "action": "Click",
    "target": [
      640,
      632
    ],
    "post_wait_freezes": 800,
    "timeout": 2000,
    "next": [
      "WaitMailboxClaimRewardSuccessClosed"
    ],
    "on_error": [
      "RetryCloseMailboxClaimRewardSuccess"
    ]
  },
  "ReturnMailboxClaimToMainAfterReward": {
    "next": [
      "ReturnMailboxClaimToMain"
    ]
  },
  "ReturnMailboxClaimToMain": {
    "next": [
      "NavReturnToMain"
    ]
  }
}
