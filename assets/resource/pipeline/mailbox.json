{
  "StartMailboxClaim": {
    "timeout": 8000,
    "rate_limit": 250,
    "next": [
      "[JumpBack]NavOpenMailbox",
      "[JumpBack]NavLoading",
      "WaitMailboxClaimPageOpened"
    ],
    "on_error": [
      "ReturnMailboxClaimToMain"
    ]
  },
  "OpenMailboxClaimFromMain": {
    "recognition": "TemplateMatch",
    "template": "main_ui/mail.png",
    "threshold": 0.58,
    "action": "Click",
    "post_wait_freezes": 500,
    "next": [
      "[JumpBack]NavLoading",
      "WaitMailboxClaimPageOpened",
      "OpenMailboxClaimFromMain"
    ],
    "roi": [
      1080,
      0,
      120,
      90
    ],
    "green_mask": true,
    "timeout": 1200,
    "rate_limit": 150
  },
  "OpenMailboxClaimLoading": {
    "recognition": "TemplateMatch",
    "template": "nav/loading.png",
    "threshold": 0.7,
    "post_wait_freezes": 300,
    "next": [
      "OpenMailboxClaimLoading",
      "WaitMailboxClaimPageOpened"
    ],
    "timeout": 700,
    "rate_limit": 100
  },
  "WaitMailboxClaimPageOpened": {
    "recognition": "TemplateMatch",
    "template": "mail/mail_title.png",
    "roi": [
      80,
      0,
      140,
      70
    ],
    "threshold": 0.7,
    "timeout": 1500,
    "next": [
      "ClickMailboxClaimAllButton",
      "ReturnMailboxClaimToMainNoClaim"
    ]
  },
  "RetryOpenMailboxClaimFromMainAfterCheck": {
    "next": [
      "OpenMailboxClaimFromMain"
    ]
  },
  "ClickMailboxClaimAllButton": {
    "recognition": "TemplateMatch",
    "template": "mail/claim_all_button.png",
    "roi": [
      990,
      615,
      290,
      105
    ],
    "threshold": 0.75,
    "action": "Click",
    "post_wait_freezes": 500,
    "timeout": 1200,
    "next": [
      "WaitMailboxClaimRewardSuccess"
    ],
    "on_error": [
      "ReturnMailboxClaimToMainNoClaim"
    ]
  },
  "ReturnMailboxClaimToMainNoClaim": {
    "next": [
      "ReturnMailboxClaimToMain"
    ]
  },
  "WaitMailboxClaimRewardSuccess": {
    "recognition": "TemplateMatch",
    "template": "mail/reward_success.png",
    "threshold": 0.8,
    "action": "Click",
    "target": [
      640,
      650
    ],
    "post_wait_freezes": 800,
    "timeout": 10000,
    "next": [
      "WaitMailboxClaimRewardSuccessClosed"
    ],
    "on_error": [
      "ContinueMailboxClaimAfterRewardTimeout"
    ]
  },
  "WaitMailboxClaimRewardSuccessClosed": {
    "recognition": "TemplateMatch",
    "template": "mail/reward_success.png",
    "threshold": 0.8,
    "inverse": true,
    "timeout": 1000,
    "next": [
      "ReturnMailboxClaimToMainAfterReward"
    ],
    "on_error": [
      "RetryCloseMailboxClaimRewardSuccess"
    ]
  },
  "RetryCloseMailboxClaimRewardSuccess": {
    "action": "Click",
    "target": [
      640,
      650
    ],
    "post_wait_freezes": 800,
    "next": [
      "WaitMailboxClaimRewardSuccessClosed"
    ]
  },
  "ContinueMailboxClaimAfterRewardTimeout": {
    "action": "Click",
    "target": [
      640,
      650
    ],
    "post_wait_freezes": 800,
    "next": [
      "ReturnMailboxClaimToMainAfterReward"
    ]
  },
  "ReturnMailboxClaimToMainAfterReward": {
    "next": [
      "ReturnMailboxClaimToMain"
    ]
  },
  "ReturnMailboxClaimToMain": {
    "timeout": 8000,
    "rate_limit": 250,
    "next": [
      "WaitMailboxClaimReturnedToMain",
      "[JumpBack]NavLoading",
      "[JumpBack]NavHomeButton",
      "[JumpBack]ClickMailboxClaimReturnBack"
    ],
    "on_error": [
      "StopMailboxClaimAfterReturnCheckTimeout"
    ]
  },
  "ClickMailboxClaimReturnBack": {
    "action": "Click",
    "target": [
      55,
      36
    ],
    "post_wait_freezes": 700
  },
  "ReturnMailboxClaimToMainLoading": {
    "recognition": "TemplateMatch",
    "template": "nav/loading.png",
    "threshold": 0.7,
    "post_wait_freezes": 300,
    "next": [
      "ReturnMailboxClaimToMainLoading",
      "WaitMailboxClaimReturnedToMain"
    ],
    "timeout": 700,
    "rate_limit": 100
  },
  "WaitMailboxClaimReturnedToMain": {
    "recognition": "TemplateMatch",
    "template": "main_ui/mail.png",
    "threshold": 0.58,
    "timeout": 1000,
    "next": [
      "Stop"
    ],
    "on_error": [
      "ReturnMailboxClaimToMainByHomeFallback"
    ],
    "roi": [
      1080,
      0,
      120,
      90
    ],
    "green_mask": true
  },
  "ReturnMailboxClaimToMainByHomeFallback": {
    "action": "Click",
    "target": [
      1237,
      36
    ],
    "post_wait_freezes": 700,
    "next": [
      "ReturnMailboxClaimToMainLoading",
      "WaitMailboxClaimReturnedToMainAfterHomeFallback"
    ]
  },
  "WaitMailboxClaimReturnedToMainAfterHomeFallback": {
    "recognition": "TemplateMatch",
    "template": "main_ui/mail.png",
    "threshold": 0.58,
    "timeout": 1000,
    "next": [
      "Stop"
    ],
    "on_error": [
      "StopMailboxClaimAfterReturnCheckTimeout"
    ],
    "roi": [
      1080,
      0,
      120,
      90
    ],
    "green_mask": true
  },
  "StopMailboxClaimAfterReturnCheckTimeout": {
    "next": [
      "Stop"
    ]
  }
}
